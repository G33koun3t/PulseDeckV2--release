{
  "name": "pulsedeck",
  "version": "1.1.2",
  "main": "src/main/main.js",
  "description": "PulseDeck - Dashboard pour Corsair Xeneon Edge",
  "author": "",
  "license": "ISC",
  "scripts": {
    "dev": "concurrently \"npm run dev:vite\" \"npm run dev:electron\"",
    "dev:vite": "vite",
    "dev:electron": "wait-on http://localhost:5173 && cross-env NODE_ENV=development ELECTRON_RUN_AS_NODE= node scripts/launch-electron.js",
    "build": "vite build",
    "start": "node scripts/launch-electron.js",
    "dist": "npm run build && electron-builder"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.1.3",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^31.7.7",
    "electron-builder": "^26.7.0",
    "vite": "^7.3.1",
    "wait-on": "^9.0.3"
  },
  "dependencies": {
    "electron-updater": "^6.7.3",
    "googleapis": "^171.2.0",
    "imap": "^0.8.19",
    "loudness": "^0.4.2",
    "lucide-react": "^0.563.0",
    "mailparser": "^3.9.3",
    "node-machine-id": "^1.1.12",
    "obs-websocket-js": "^5.0.7",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "recharts": "^3.7.0",
    "rss-parser": "^3.13.0",
    "speedtest-net": "^2.2.0",
    "systeminformation": "^5.30.7"
  },
  "build": {
    "appId": "com.pulsedeck.app",
    "productName": "PulseDeck",
    "directories": {
      "output": "release"
    },
    "files": [
      "src/main/**/*",
      "dist/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "scripts/",
        "to": "scripts/",
        "filter": [
          "*.ps1"
        ]
      },
      {
        "from": "monitoring.ico",
        "to": "monitoring.ico"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "monitoring.ico",
      "signAndEditExecutable": false
    },
    "afterPack": "./scripts/afterPack.js",
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    },
    "asarUnpack": [
      "**/speedtest-net/binaries/**",
      "**/loudness/**"
    ],
    "asar": true,
    "electronDist": "node_modules/electron/dist",
    "publish": {
      "provider": "github",
      "owner": "G33koun3t",
      "repo": "PulseDeck--release",
      "releaseType": "release"
    }
  }
}
